// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "mongodb"
    url      = env("DATABASE_URL")
}

// --------------------------------------
// 1. Identity & SaaS Multi-Tenancy
// --------------------------------------

enum SubscriptionPlan {
    FREE
    PRO
    UNLIMITED
}

enum SubscriptionStatus {
    ACTIVE
    PAST_DUE
    CANCELED
    TRIALING
    UNPAID
}

model Agency {
    id           String  @id @default(cuid()) @map("_id")
    agencyNo     String?
    agencyName   String
    operatorName String?
    email        String? @unique

    // --- BILLING INFO ---
    stripeCustomerId String? // Stripe Customer ID
    hasPaymentMethod Boolean @default(false) // UI: "Card Linked" status
    billingAddress   String? // For Invoice Generation

    latitude  Float? // Office Location
    longitude Float? // Office Location
    radius    Int    @default(100) // Meters allowed for check-in

    address String? // UI: Physical address in Hurghada

    // Office Schedule
    workingHours WorkingDay[]

    subscription Subscription?
    users        User[]
    projects     Project[]
    clients      Client[]
    assets       Asset[]
    expenses     Expense[]
    payments     Payment[]

    createdAt      DateTime        @default(now())
    updatedAt      DateTime        @updatedAt
    payouts        Payout[]
    attendanceLogs AttendanceLog[]
    tasks          Task[]
    taskExpenses   TaskExpense[]
    comments       Comment[]
    notifications  Notification[]
    agencyInvoices AgencyInvoice[]
}

type WorkingDay {
    day       String // "Monday", "Tuesday", etc.
    openTime  String // "09:00"
    closeTime String // "17:00"
    isClosed  Boolean @default(false)
}

model Subscription {
    id       String             @id @default(cuid()) @map("_id")
    agencyId String             @unique
    agency   Agency             @relation(fields: [agencyId], references: [id])
    plan     SubscriptionPlan   @default(FREE)
    status   SubscriptionStatus @default(TRIALING)

    // --- STRIPE / PAYMENT SYNC ---
    stripeSubscriptionId String? // The ID of the recurring sub in Stripe
    stripePriceId        String? // To track which specific price they are paying

    // Billing Period Tracking
    currentPeriodStart DateTime? // When the current month started
    currentPeriodEnd   DateTime? // When the next payment is due
    cancelAtPeriodEnd  Boolean   @default(false) // If they turned off auto-renew

    // Business Logic Limits
    maxUsers       Int     @default(5)
    maxProjects    Int     @default(50)
    hasAssetAccess Boolean @default(false)

    // Feature Gates
    geoFencingEnabled Boolean @default(false)
    advancedReporting Boolean @default(false)
    hasGeoTracking    Boolean @default(false)
    hasNotifications  Boolean @default(true)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

enum InvoiceType {
    SUBSCRIPTION
    BUNDLE
    ADDON
}

model AgencyInvoice {
    id       String      @id @default(cuid()) @map("_id")
    agencyId String
    agency   Agency      @relation(fields: [agencyId], references: [id])
    type     InvoiceType @default(SUBSCRIPTION)

    amount          Float // e.g., 99.00
    currency        String  @default("USD")
    status          String // "PAID", "OPEN", "VOID"
    stripeInvoiceId String? @unique
    pdfUrl          String? // Link to the Stripe hosted invoice

    plan        SubscriptionPlan
    periodStart DateTime
    periodEnd   DateTime

    createdAt DateTime @default(now())
}

// --------------------------------------
// 2. Users & HR
// --------------------------------------

enum UserType {
    FULL_TIME
    PART_TIME
    FREELANCER
    INTERN
}

enum UserRole {
    SUPERADMIN
    ADMIN
    OPERATOR
    CREATIVE
}

model User {
    id       String   @id @default(cuid()) @map("_id")
    userNo   String?
    name     String
    email    String   @unique
    password String?
    userType UserType @default(FULL_TIME)
    role     UserRole @default(CREATIVE)

    salary Float? @default(0.0)

    verifiedSkills String[]
    efficiencyRate Float?   @default(1.0)
    leaves         Leave[]

    agencyId String
    agency   Agency @relation(fields: [agencyId], references: [id])

    attendanceLogs AttendanceLog[]
    tasks          Task[]
    comments       Comment[]

    createdAt     DateTime       @default(now())
    expenses      Expense[]
    payouts       Payout[]
    notifications Notification[]
}

type Leave {
    startDate  DateTime?
    endDate    DateTime?
    type       String
    status     String    @default("PENDING")
    reason     String?
    agencyId   String?
    approvedBy String? // Store the name or ID of the manager
    updatedAt  DateTime  @default(now())
    createdAt  DateTime  @default(now())
}

model AttendanceLog {
    id           String    @id @default(cuid()) @map("_id")
    date         DateTime  @default(now())
    checkInTime  DateTime
    checkOutTime DateTime?
    status       String
    userId       String
    user         User      @relation(fields: [userId], references: [id])

    type AttendanceType @default(OFFICE)

    isLate          Boolean @default(false)
    checkInLocation String? // "OFFICE", "FIELD_TASK", "REMOTE"

    agencyId String
    agency   Agency @relation(fields: [agencyId], references: [id])

    // Geo-Validation
    checkInLat Float?
    checkInLng Float?

    totalHours Float? // Calculated on check-out

    createdAt DateTime @default(now())
}

enum AttendanceType {
    OFFICE
    FIELD_TASK
}

// --------------------------------------
// 3. Client & Project Management
// --------------------------------------

enum InvoiceStatus {
    DRAFT
    SENT
    PARTIALLY_PAID
    PAID
    OVERDUE
    VOID
}

model Client {
    id          String  @id @default(cuid()) @map("_id")
    clientNo    String?
    clientName  String
    accountType String
    status      String

    agencyId String
    agency   Agency @relation(fields: [agencyId], references: [id])

    projects Project[]
    payments Payment[]

    createdAt DateTime @default(now())
}

model Project {
    id             String   @id @default(cuid()) @map("_id")
    projectNo      String?
    projectName    String
    targetDeadline DateTime
    status         String
    projectStory   String?
    cloudLink      String?

    // FINANCIAL DATA (The Invoice Part)
    totalValue    Float // This IS the invoice amount (The DEBIT)
    invoiceNo     String? // Optional: For professional tracking like "INV-101"
    invoiceStatus InvoiceStatus @default(DRAFT) // UI: "In Production", "Paid", "Overdue"

    agencyId String
    agency   Agency @relation(fields: [agencyId], references: [id])

    clientId String
    client   Client @relation(fields: [clientId], references: [id])

    tasks Task[]

    createdAt    DateTime      @default(now())
    updatedAt    DateTime      @updatedAt
    taskExpenses TaskExpense[]
}

// --------------------------------------
// 4. Production & Rentals
// --------------------------------------

model Task {
    id          String  @id @default(cuid()) @map("_id")
    taskNo      String?
    taskType    String // UI: "CONSULTATION", "VIDEO", etc.
    progress    Int     @default(0)
    status      String
    actualHours Float   @default(0.0) // Total hours logged here

    paymentStatus String @default("Pending")

    // UI: FINANCIALS PER DEPT
    internalCost Float @default(0.0) // UI: "GROSS REVENUE ($)"
    margin       Float @default(30.0) // UI: "MARGIN (%)"

    // UI: TIMELINE
    startDate DateTime // UI: "DEPLOYMENT START"
    endDate   DateTime // UI: "PROJECT CONCLUSION"

    // UI: SCOPE & DELIVERABLES
    description String?

    priority   String  @default("MEDIUM") // "URGENT", "HIGH", "MEDIUM"
    isNotified Boolean @default(false) // To prevent spamming alerts

    // NEW: Geofencing for the specific Shoot
    locationName String? // e.g., "Steigenberger Al Dau"
    latitude     Float?
    longitude    Float?
    radius       Int     @default(200) // Meters allowed for "Arrived" status

    // Tracking the Time Spent on this specific location
    arrivalAt   DateTime?
    departureAt DateTime?

    // RELATIONS
    projectId String
    project   Project @relation(fields: [projectId], references: [id])

    assigneeId String?
    assignee   User?   @relation(fields: [assigneeId], references: [id])

    assetIds String[]
    assets   Asset[]  @relation(fields: [assetIds], references: [id])

    agencyId String
    agency   Agency @relation(fields: [agencyId], references: [id])

    // NEW: EXTERNAL RENTALS
    taskExpenses TaskExpense[]

    comments            Comment[]
    lastUpdateTimestamp DateTime  @updatedAt

    createdAt DateTime @default(now())
}

model TaskExpense {
    id          String  @id @default(cuid()) @map("_id")
    itemName    String // UI: "Camera Rental", "Location Fee", "Lunch"
    cost        Float // UI: "Cost $"
    category    String // UI: "RENTAL", "TRAVEL", "HOSPITALITY", "MISC"
    description String?

    taskId String
    task   Task   @relation(fields: [taskId], references: [id])

    projectId String?
    project   Project? @relation(fields: [projectId], references: [id])

    agencyId String
    agency   Agency @relation(fields: [agencyId], references: [id])

    createdAt DateTime @default(now())
}

model Comment {
    id        String   @id @default(cuid()) @map("_id")
    text      String
    authorId  String?
    author    User?    @relation(fields: [authorId], references: [id])
    taskId    String
    task      Task     @relation(fields: [taskId], references: [id])
    createdAt DateTime @default(now())

    agencyId String
    agency   Agency @relation(fields: [agencyId], references: [id])
}

// --------------------------------------
// 5. Payments & Assets
// --------------------------------------

model Payment {
    id          String   @id @default(cuid()) @map("_id")
    paymentNo   String?
    amount      Float
    method      String
    datePaid    DateTime
    description String?

    agencyId String
    agency   Agency @relation(fields: [agencyId], references: [id])
    clientId String
    client   Client @relation(fields: [clientId], references: [id])

    createdAt DateTime @default(now())
}

model Asset {
    id                 String   @id @default(cuid()) @map("_id")
    assetNo            String?
    assetName          String
    category           String
    purchaseDate       DateTime
    currentValue       Float
    availabilityStatus String

    agencyId String
    agency   Agency @relation(fields: [agencyId], references: [id])

    taskIds String[]
    tasks   Task[]   @relation(fields: [taskIds], references: [id])

    createdAt DateTime @default(now())
}

model Expense {
    id           String   @id @default(cuid()) @map("_id")
    expenseNo    String?
    resourceName String
    category     String
    amount       Float
    status       String
    date         DateTime
    description  String?
    agencyId     String
    agency       Agency   @relation(fields: [agencyId], references: [id])

    userId String? @map("userId")
    user   User?   @relation(fields: [userId], references: [id])

    createdAt DateTime @default(now())
}

model Payout {
    id          String   @id @default(cuid()) @map("_id")
    payoutNo    String?
    amount      Float
    category    String // e.g., "Salary", "Bonus", "Commission"
    status      String   @default("PAID")
    date        DateTime @default(now())
    description String?

    // Relation to Employee
    userId String
    user   User   @relation(fields: [userId], references: [id])

    // Relation to Agency (for security)
    agencyId String
    agency   Agency @relation(fields: [agencyId], references: [id])

    createdAt DateTime @default(now())
}

model Notification {
    id      String  @id @default(cuid()) @map("_id")
    title   String
    message String
    type    String // "DEADLINE", "ASSIGNMENT", "SYSTEM"
    isRead  Boolean @default(false)

    userId String
    user   User   @relation(fields: [userId], references: [id])

    agencyId String
    agency   Agency @relation(fields: [agencyId], references: [id])

    createdAt DateTime @default(now())
}
